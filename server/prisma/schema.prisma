
generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum Role {
  adopter
  shelter_staff
  admin
}
enum PetStatus {
  available
  pending
  adopted
}

model User {
  id String @id @default(uuid())
  email String @unique
  name String
  password_hash String
  role Role @default(adopter)
  created_at DateTime @default(now())
  shelters Shelter[]
}
model Shelter {
  id String @id @default(uuid())
  owner_user_id String
  name String
  description String?
  address String
  is_verified Boolean @default(false)
  created_at DateTime @default(now())

owner User @relation(fields: [owner_user_id], references: [id])
pets Pet[]
}
model Pet {
  id String @id @default(uuid())
  shelter_id String
  name String
  species String
  breed String?
  age Int?
  description String?
  photo_url String?
  status PetStatus @default(available)
  created_at DateTime @default(now())

  shelter Shelter @relation(fields: [shelter_id], references: [id])
}