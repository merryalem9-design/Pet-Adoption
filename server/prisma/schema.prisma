
generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum Role {
  adopter
  shelter_staff
  admin
}
model User {
  id String @id @default(uuid())
  email String @unique
  name String
  password_hash String
  role Role @default(adopter)
  created_at DateTime @default(now())
}