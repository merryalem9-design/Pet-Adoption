
generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
enum Role {
  adopter
  shelter_staff
  admin
}
enum PetStatus {
  available
  pending
  adopted
}
enum ApplicationStatus {
  submitted
  approved
  rejected
  adopted
}
model User {
  id String @id @default(uuid())
  email String @unique
  name String
  password_hash String
  role Role @default(adopter)
  created_at DateTime @default(now())
  shelters Shelter[]
  favorites Favorite[]
  applications Application[]
}
model Shelter {
  id String @id @default(uuid())
  owner_user_id String
  name String
  description String?
  address String
  is_verified Boolean @default(false)
  created_at DateTime @default(now())

owner User @relation(fields: [owner_user_id], references: [id])
pets Pet[]
}
model Pet {
  id String @id @default(uuid())
  shelter_id String
  name String
  species String
  breed String?
  age Int?
  description String?
  photo_url String?
  status PetStatus @default(available)
  created_at DateTime @default(now())

  shelter Shelter @relation(fields: [shelter_id], references: [id])
  favorites Favorite[]
  applications Application[]
}
model Favorite {
  id String @id @default(uuid())
  user_id String
  pet_id String
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])
  pet Pet @relation(fields: [pet_id], references: [id])

  @@unique([user_id, pet_id])
}
model Application {
  id String @id @default(uuid())
  pet_id String
  adopter_id String
  status ApplicationStatus @default(submitted)
  message String?
  created_at DateTime @default(now())

  pet Pet @relation(fields: [pet_id], references: [id])
  adopter User @relation(fields: [adopter_id], references: [id])
}